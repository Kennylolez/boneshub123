local dragging = false
local dragInput, dragStart, startPos

local function updatePos(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(
        startPos.X.Scale, startPos.X.Offset + delta.X,
        startPos.Y.Scale, startPos.Y.Offset + delta.Y
    )
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updatePos(input)
    end
end)

local function getDropRemote()
    local r = ReplicatedStorage:FindFirstChild("DropBallEvent")
    if not r then r = ReplicatedStorage:WaitForChild("DropBallEvent", 3) end
    return r
end

local function getRollRemote()
    local r = ReplicatedStorage:FindFirstChild("RollEvent")
    if not r then r = ReplicatedStorage:WaitForChild("RollEvent", 3) end
    return r
end

local function getRebirthRemote()
    local r = ReplicatedStorage:FindFirstChild("RebirthEvent")
    if not r then r = ReplicatedStorage:WaitForChild("RebirthEvent", 3) end
    return r
end

local function getShootRemotes()
    local remotes = {}
    local names = {"ShootBallFunc", "ShootTargetFunc", "ShootBallEvent"}
    for _, name in pairs(names) do
        local r = ReplicatedStorage:FindFirstChild(name)
        if r then
            table.insert(remotes, r)
        end
    end
    return remotes
end

local function fireRemote(remote)
    if not remote then return end
    if remote:IsA("RemoteEvent") then
        remote:FireServer()
    elseif remote:IsA("RemoteFunction") then
        remote:InvokeServer()
    else
        remote:Fire()
    end
end

local function fireRemoteAsync(remote)
    task.spawn(function()
        if not remote then return end
        if remote:IsA("RemoteEvent") then
            remote:FireServer()
        elseif remote:IsA("RemoteFunction") then
            pcall(function()
                if remote.Name == "ShootBallFunc" then
                    remote:InvokeServer("Normal", true)
                else
                    remote:InvokeServer()
                end
            end)
        else
            remote:Fire()
        end
    end)
end

local function toggleDrop()
    dropEnabled = not dropEnabled
    if dropEnabled then
        DropBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 80)
        DropBtn.Text = "开"
        dropTask = task.spawn(function()
            local remote = getDropRemote()
            if not remote then return end
            while dropEnabled do
                fireRemote(remote)
                task.wait()
            end
        end)
    else
        DropBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        DropBtn.Text = "关"
        if dropTask then task.cancel(dropTask) dropTask = nil end
    end
end

