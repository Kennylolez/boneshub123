local function toggleShoot()
    shootEnabled = not shootEnabled
    if shootEnabled then
        ShootBtn.BackgroundColor3 = Color3.fromRGB(40, 160, 80)
        ShootBtn.Text = "开"
        shootTask = task.spawn(function()
            local remotes = getShootRemotes()
            if #remotes == 0 then return end
            while shootEnabled do
                for _, remote in pairs(remotes) do
                    fireRemoteAsync(remote)
                end
                task.wait()
            end
        end)
    else
        ShootBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        ShootBtn.Text = "关"
        if shootTask then task.cancel(shootTask) shootTask = nil end
    end
end

